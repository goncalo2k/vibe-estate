{
  "name": "@property-agg/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/rpc.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply property-agg-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply property-agg-db --remote"
  },
  "dependencies": {
    "@property-agg/shared": "workspace:*",
    "hono": "^4",
    "@hono/zod-validator": "^0.4",
    "node-html-parser": "^6",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "typescript": "^5.7",
    "vitest": "^2",
    "wrangler": "^3"
  }
}
