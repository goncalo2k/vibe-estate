{
  "name": "@property-agg/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/rpc.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "ship": "wrangler deploy",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply estate-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply estate-db --remote",
    "trigger": "curl -s -X POST http://localhost:8787/api/trigger/${JOB:-all} | jq",
    "trigger:scrape": "JOB=scrape pnpm trigger",
    "trigger:analyze": "JOB=analyze pnpm trigger",
    "trigger:notify": "JOB=notify pnpm trigger",
    "trigger:stale": "JOB=stale pnpm trigger"
  },
  "dependencies": {
    "@property-agg/shared": "workspace:*",
    "hono": "^4",
    "@hono/zod-validator": "^0.4",
    "node-html-parser": "^6",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.1",
    "typescript": "^5.7",
    "vitest": "^2",
    "wrangler": "^4"
  }
}
